{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@deck.gl/aggregation-layers": ["src/types/deck-gl-loose.d.ts"],
      "@deck.gl/core": ["src/types/deck-gl-loose.d.ts"],
      "@deck.gl/extensions": ["src/types/deck-gl-loose.d.ts"],
      "@deck.gl/geo-layers": ["src/types/deck-gl-loose.d.ts"],
      "@deck.gl/layers": ["src/types/deck-gl-loose.d.ts"],
      "@deck.gl/mapbox": ["src/types/deck-gl-loose.d.ts"],
      "@dodopayments/core": ["src/types/dodopayments-core.d.ts"],
      "convex/browser": ["node_modules/convex/dist/cjs-types/browser/index.d.ts"],
      "convex/server": ["node_modules/convex/dist/cjs-types/server/index.d.ts"],
      "convex/values": ["node_modules/convex/dist/cjs-types/values/index.d.ts"],
      "hls.js": ["src/types/hls-js.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/workers/ml.worker.ts"]
}
